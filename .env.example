# ===========================================
# Required
# ===========================================

# Supabase — get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# Optional
# ===========================================

# Google Maps Geocoding (falls back to Nominatim/OpenStreetMap if not set)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Resend — email notifications when sellers are contacted
# Sign up at https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=TrashTrove <noreply@yourdomain.com>

# Site URL — used for email links and OG images
# In development this defaults to localhost; set in production
NEXT_PUBLIC_SITE_URL=https://trashtrove.app
